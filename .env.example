# --- Öffentlich (im Browser sichtbar) ---
NEXT_PUBLIC_GRAPHQL_URL=https://example.com/graphql

# Google Tag Manager (Container-ID ist öffentlich im HTML — kein Secret)
# Weglassen oder auskommentiert: es wird GTM-M33MB2FV verwendet (Fallback im Root-Layout).
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
# Explizit leer setzen zum Abschalten: NEXT_PUBLIC_GTM_ID=

# Google Analytics 4 (Measurement ID, öffentlich)
# Weglassen: Fallback G-WFQGYYGWTR (siehe src/lib/analytics.ts)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Abschalten: NEXT_PUBLIC_GA_MEASUREMENT_ID=

# --- Nur Server (Next.js Route Handlers / SSR) ---
# Headless-Checkout: Zahlungsliste aus Store API wird standardmäßig um bacs ergänzt (siehe /api/checkout/payment-options).
# Nur setzen, wenn Banküberweisung in Woo wirklich aus und nicht angeboten werden soll:
# CHECKOUT_SUPPLEMENT_BACS=0

# Produktseite: Cache-Zeit in Sekunden für GraphQL/Customizer (unstable_cache + fetch revalidate).
# Hinweis: `export const revalidate` in page.tsx muss in Code feststehen (Vercel/Next.js); dieses ENV steuert nur die Datenlayer-Caches.
PRODUCT_PAGE_REVALIDATE_SECONDS=300

# Bevorzugt: gleiche URL wie oben, aber nicht im Client-Bundle (GraphQL-Proxy /api/graphql)
GRAPHQL_SERVER_URL=

# WooCommerce Customizer REST (Basis-URL ohne trailing slash, Endpunkt /{productId} wird angehängt)
CUSTOMIZER_API_URL=https://example.com/wp-json/planenadler-customizer/v1/config
# Optional: wenn in wp-config.php define('PLANENADLER_CUSTOMIZER_REST_KEY', '...'); gesetzt ist
CUSTOMIZER_REST_API_KEY=

# WordPress admin-ajax für Preisberechnung
WP_AJAX_URL=https://example.com/wp-admin/admin-ajax.php
# Optional: muss mit wp-config define('PLANENADLER_AJAX_SECRET', '...'); übereinstimmen (Plugin product-customize)
PLANENADLER_AJAX_SECRET=

# Google Places (nur serverseitig verwenden)
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
